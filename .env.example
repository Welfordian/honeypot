NODE_ENV=development

# Generate with: openssl rand -hex 32
INGEST_HMAC_SECRET=replace-with-a-strong-shared-secret

# Host-level capture talks to the local loopback writer; Docker sensors use Compose-internal URLs.
COLLECTOR_URL=http://127.0.0.1:3100/internal/ingest/events
CLOUDFLARE_INGEST_URL=https://honeypot-r2-indexer.example.workers.dev/internal/ingest/events
CLOUDFLARE_PCAP_INGEST_URL=https://honeypot-r2-indexer.example.workers.dev/internal/ingest/pcap

RETENTION_RAW_DAYS=180
MAX_PAYLOAD_BYTES=32768
# 203.0.113.* addresses are RFC 5737 documentation examples only — replace with your VPS public IP and admin/source IPs.
SUPPRESSED_SOURCE_IPS=203.0.113.10
CAPTURE_INTERFACE=enp1s0
PUBLIC_IP=203.0.113.20
ADMIN_SSH_PORT=22222
GENERIC_BANNER_PORT=65000
PCAP_SPOOL_DIR=/var/spool/honeypot-capture
PCAP_ROTATE_SECONDS=60
PCAP_MAX_MB=8
PCAP_MAX_SPOOL_BYTES=268435456
INGEST_TIMEOUT_MS=8000
INGEST_CONCURRENCY=4
INGEST_QUEUE_MAX=5000
TRAP_TLS_KEY_PATH=
TRAP_TLS_CERT_PATH=

# Cloudflare project settings used by Wrangler (dashboard at https://dashboard.example.com).
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
D1_DATABASE_NAME=honeypot-analytics
D1_DATABASE_ID=replace-after-wrangler-d1-create
CLOUDFLARE_PAGES_PROJECT=honeypot-sec

# Empty means same-origin at your dashboard hostname.
VITE_API_BASE_URL=
